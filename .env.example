# Copy this file to .env.local before running the app.
#
# Local Supabase defaults usually come from `supabase status`.
# For hosted deployments, replace the localhost values with your project URL and keys.

# Public app URL used for auth callback redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL and public anon key.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Frontend data source.
# Keep `api` for the real backend demo flow.
# Change to `mock` only if you intentionally want the UI-only fallback adapter.
NEXT_PUBLIC_STUDY_FOCUS_DATA_SOURCE=api
NEXT_PUBLIC_STUDY_FOCUS_API_BASE_URL=/api

# Required for `npm run seed`.
# Do not expose this key to the browser or client-side code.
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
