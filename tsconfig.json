{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@study-focus-shared": [
        "./study-focus-shared/src/index.ts"
      ],
      "@study-focus-shared/*": [
        "./study-focus-shared/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-local/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-qa-build/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
